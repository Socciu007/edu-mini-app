{
  "name": "edu-mini-app",
  "private": true,
  "version": "1.0.0",
  "description": "Mini App Name",
  "repository": "",
  "license": "UNLICENSED",
  "browserslist": [
    "Android >= 5",
    "IOS >= 9.3",
    "Edge >= 15",
    "Safari >= 9.1",
    "Chrome >= 49",
    "Firefox >= 31",
    "Samsung >= 5"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:template": "cd template && vite build && cp app-config.json ./www",
    "dev": "vite dev --port 3000 --host 127.0.0.1",
    "deploy": "npm run build && zmp-cli deploy --existing",
    "deploy:live": "npm run build && zmp-cli deploy --existing --testing --desc",
    "lint": "eslint --ext .ts,.tsx src",
    "fix": "eslint --ext .ts,.tsx src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.23",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dayjs": "^1.11.10",
    "immer": "^10.0.3",
    "katex": "^0.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.12",
    "react-router-dom": "^6.22.1",
    "tailwind-merge": "^2.2.1",
    "usehooks-ts": "^2.15.0",
    "zmp-sdk": "^2.39.9",
    "zmp-ui": "^1.11.5",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.53",
    "@types/react-dom": "^18.2.18",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.9",
    "@xuannghia/eslint-config": "^1.0.2",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.33",
    "postcss-preset-env": "^10.0.2",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^4.1.9",
    "zmp-vite-plugin": "^1.1.6"
  }
}
